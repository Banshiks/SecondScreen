<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
    app:cardBackgroundColor="#1A1A2E" app:cardCornerRadius="16dp" app:cardElevation="0dp"
    app:strokeColor="#2A2A4A" app:strokeWidth="1dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#128250;" android:textSize="22sp" android:layout_marginRight="14dp"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Устройство доступно" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:layout_marginBottom="2dp"/>
            <TextView android:id="@+id/tvDeviceIp" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="192.168.1.1"
                android:textSize="12sp" android:textColor="#7070A0"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Смотреть &#8250;" android:textSize="13sp"
            android:textColor="#7C4DFF" android:textStyle="bold"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
